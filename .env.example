# Polar (polar.sh) 결제 환경변수 템플릿
# 이 파일을 복사해 .env를 만들고 실제 값을 채우세요: cp .env.example .env
# 키 발급: https://polar.sh → Settings → Developers → Access Tokens

# --- Firebase (콘솔 > 프로젝트 설정 > 일반 > SDK 설정 및 구성) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- 클라이언트 노출용 (VITE_ 접두사 = 브라우저 접근 가능, 비밀키 금지) ---
VITE_POLAR_SERVER=sandbox
VITE_POLAR_CHECKOUT_LINK=
VITE_POLAR_SUCCESS_URL=http://localhost:5173/order-complete

# --- 서버 전용 (백엔드/서버리스에서만 사용, VITE_ 접두사 금지) ---
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
